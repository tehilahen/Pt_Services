# העתק ל-.env והתאם (הקובץ .env לא נכנס ל-git)

# נתיב קובץ SQLite — ברירת מחדל: תיקיית backend/data/demo.sqlite
SQLITE_DB_PATH=data/demo.sqlite

FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

SECRET_KEY=החלף-מפתח-ארוך
JWT_SECRET_KEY=החלף-מפתח-jwt
JWT_EXPIRATION_HOURS=24

CORS_ORIGINS=http://localhost:3000
