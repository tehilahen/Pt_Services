###############################################################################
# PURPOSE:
# JSON Reporting with CVSS Integration
###############################################################################

sub nikto_report_json_cvss_init {
    use JSON::PP;
    my $id = { name              => "report_json_cvss",
               full_name         => "JSON reports with CVSS",
               author            => "CVSS Integration Team",
               description       => "Produces a JSON report with CVSS scores and severity levels.",
               report_head       => \&json_cvss_open,
               report_host_start => \&json_cvss_host_start,
               report_host_end   => \&json_cvss_host_end,
               report_close      => \&json_cvss_close,
               report_item       => \&json_cvss_item,
               report_format     => 'json_cvss',
               copyright         => "2024 CVSS Integration Team"
               };
    return $id;
}

###############################################################################
# open output file
sub json_cvss_open {
    my ($file) = @_;

    # Open file and produce header
    open(OUT, "+>$file") || die print STDERR "+ ERROR: Unable to open '$file' for write: $@\n";
    print OUT "[";

    return OUT;
}

###############################################################################
# start output
$json_cvss_host_started = false;
sub json_cvss_host_start {
    my ($handle, $mark) = @_;
    $mark->{'banner'} =~ s/"/\\"/g;
    my $hostname = $mark->{'vhost'} ? $mark->{'vhost'} : $mark->{'hostname'};

    if ($json_cvss_host_started eq true) { print $handle ","; }

    print $handle "{\"host\":\"$hostname\","
      . "\"ip\":\"$mark->{'ip'}\","
      . "\"port\":\"$mark->{'port'}\","
      . "\"banner\":\"$mark->{'banner'}\","
      . "\"vulnerabilities\":[";

    $json_cvss_host_started = true;
    return;
}

###############################################################################
# end output
sub json_cvss_host_end {
    my ($handle, $mark, $file) = @_;

    if ($json_cvss_host_started eq true) { print OUT "]}"; }
    $json_cvss_item_count = 0;
    return;
}

###############################################################################
# close output file
sub json_cvss_close {
    my ($handle, $mark) = @_;
    print $handle "]";
    close($handle);
    return;
}

###############################################################################
# print an item with CVSS information
$json_cvss_item_count = 0;
sub json_cvss_item {
    my ($handle, $mark, $item) = @_;
    $json_cvss_item_count++;

    $uri = $item->{'uri'};
    my $line = "";

    if ($json_cvss_item_count gt 1) { $line .= ","; }

    $line .= "{";
    $line .= "\"id\": \"" . $item->{'nikto_id'} . "\",";
    if ($item->{'refs'} ne '')   { $line .= "\"references\": \"" . $item->{'refs'} . "\","; }
    if ($item->{'method'} ne '') { $line .= "\"method\":\"" . $item->{'method'} . "\","; }
    if (($uri ne '') && ($mark->{'root'} ne '') && ($uri !~ /^$mark->{'root'}/)) {
        $line .= "\"url\":\"" . $mark->{'root'} . $uri . "\",";
    }
    else { $line .= "\"url\":\"" . $uri . "\","; }

    my $msg = $item->{'message'};
    $uri = quotemeta($uri);
    my $root = quotemeta($mark->{'root'});
    $msg =~ s/^$uri:\s//;
    $msg =~ s/^$root$uri:\s//;
    $msg =~ s/"/\\"/g;
    $msg = JSON::PP->new->encode($msg);
    $line .= "\"msg\":$msg";
    
    # Add CVSS information if available
    if ($item->{'cvss_score'}) {
        $line .= ",\"cvss_score\":" . $item->{'cvss_score'};
    }
    if ($item->{'severity'}) {
        $line .= ",\"severity\":\"" . $item->{'severity'} . "\"";
    }
    if ($item->{'cve'}) {
        $line .= ",\"cve\":\"" . $item->{'cve'} . "\"";
    }
    if ($item->{'cvss_confidence'}) {
        $line .= ",\"cvss_confidence\":\"" . $item->{'cvss_confidence'} . "\"";
    }
    
    $line .= "}";
    print $handle $line;
}

1;

